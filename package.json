{
  "name": "svetoplavci-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run db:assert:local-safe && next dev",
    "dev:unsafe": "ALLOW_UNSAFE_DB=1 next dev",
    "build": "prisma generate && prisma db push && next build",
    "start": "next start",
    "lint": "eslint",
    "coda:columns": "node scripts/list-coda-columns.mjs",
    "db:assert:local-safe": "node scripts/db/assert-safe-local-db.mjs",
    "db:dev-template:refresh": "node scripts/db/neon-dev-branches.mjs refresh-template",
    "db:dev-branch:create": "node scripts/db/neon-dev-branches.mjs create-dev",
    "db:dev-branch:reset": "node scripts/db/neon-dev-branches.mjs reset-dev",
    "db:dev-branch:list": "node scripts/db/neon-dev-branches.mjs list",
    "policy:guard": "node scripts/policy/enforce-promotion-policy.mjs"
  },
  "dependencies": {
    "@auth/core": "^0.41.0",
    "@auth/prisma-adapter": "^2.11.1",
    "@neondatabase/serverless": "^1.0.2",
    "@prisma/adapter-neon": "^7.3.0",
    "@prisma/adapter-pg": "^7.6.0",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.563.0",
    "next": "16.1.6",
    "next-auth": "^5.0.0-beta.30",
    "nodemailer": "^7.0.13",
    "pg": "^8.20.0",
    "plotly.js-basic-dist-min": "^3.3.1",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwind-merge": "^3.4.0"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "devDependencies": {
    "@prisma/client": "^7.3.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/plotly.js-basic-dist-min": "^2.12.4",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.2.4",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prisma": "^7.3.0",
    "shadcn": "^3.8.4",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}
