model MirrorHodnoceniOblasti {
  codaRowId     String    @id @map("coda_row_id")
  codaCreatedAt DateTime? @map("coda_created_at")
  codaUpdatedAt DateTime? @map("coda_updated_at")
  syncedAt      DateTime  @default(now()) @map("synced_at")
