// Auth.js (NextAuth) + magic link – User, Account, Session, VerificationToken
// https://authjs.dev/getting-started/adapters/prisma
//
// Mirror tabulky = jednosměrná kopie dat z Coda (sync 2x denně).
// Schéma je záměrně jednoduché: coda_row_id (PK) + data JSONB.
// V Phase 3 budou nahrazeny normalizovanými tabulkami.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AppGroupKind {
  stupen
  rocnik
  smecka
  posadka
  studijni_skupina
}

enum AppStudyModeKey {
  denni
  individualni
  zahranici
  unknown
}

enum AppPolicyScope {
  global
  study_mode
  role
}

enum AppCalendarProvider {
  GOOGLE_WORKSPACE
}

enum AppCalendarTarget {
  STUDENT
  GROUP
  BOTH
}

enum AppCalendarBehavior {
  NONE
  SEPARATE_EVENT
  UPDATE_LINKED_LESSON
}

enum AppScheduleLinkPolicy {
  NONE
  OPTIONAL
  REQUIRED
}

enum AppEventGroupSource {
  NONE
  SMECKA
  POSADKA
  KURZ
}

enum AppCalendarEventLinkStatus {
  ACTIVE
  CANCELED
  DELETED
}

enum AppCalendarSyncJobType {
  ENSURE_STUDENT_CALENDAR
  ENSURE_GROUP_CALENDAR
  INITIAL_STUDENT_SYNC
  REFRESH_STUDENT_DAY
  REFRESH_GROUP_DAY
  PROCESS_CHANGE_DELTA
  UPSERT_SCHOOL_EVENT
}

enum AppCalendarSyncJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELED
}

enum AppSchoolEventTargetType {
  PERSON
  GROUP
}

enum AppSchoolEventVisibility {
  PRIVATE
  INVITE_ONLY
  PUBLIC
}

enum AppSchoolEventLifecycleStatus {
  DRAFT
  PUBLISHED
  REGISTRATION_CLOSED
  COMPLETED
  CANCELED
  ARCHIVED
}

enum AppSchoolEventAudienceRuleType {
  PERSON
  GROUP
  ROLE
  EXPRESSION
  PUBLIC
}

enum AppSchoolEventSnapshotReason {
  PUBLISHED
  REGISTRATION_CLOSED
  MANUAL
}

enum AppSchoolEventRegistrationWindowMode {
  ABSOLUTE
  RELATIVE_TO_EVENT_START
}

enum AppSchoolEventRegistrationStatus {
  REGISTERED
  UNREGISTERED
  WAITLIST
  CANCELED_BY_GUIDE
}

enum AppSchoolEventAttendanceStatus {
  PRESENT
  ABSENT
  EXCUSED
  LATE
  LEFT_EARLY
}

enum AppSchoolEventOfferSelectionMode {
  AT_MOST_ONE
  EXACTLY_ONE
}

enum AppSchoolEventModuleLinkTargetType {
  EVENT
  REGISTRATION
  ATTENDANCE
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  accounts Account[]
  sessions Session[]
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Mirror tabulky (Coda → PostgreSQL) ──────────────────────────────────────

model MirrorSeznamOsob {
  codaRowId     String    @id @map("coda_row_id")
  codaCreatedAt DateTime? @map("coda_created_at")
  codaUpdatedAt DateTime? @map("coda_updated_at")
  syncedAt      DateTime  @default(now()) @map("synced_at")
  data          Json

  @@map("mirror_seznam_osob")
}

model MirrorOsobniLodicky {
  codaRowId     String    @id @map("coda_row_id")
  codaCreatedAt DateTime? @map("coda_created_at")
  codaUpdatedAt DateTime? @map("coda_updated_at")
  syncedAt      DateTime  @default(now()) @map("synced_at")
  data          Json

  @@map("mirror_osobni_lodicky")
}

model MirrorLodickyPoPlavbach {
  codaRowId     String    @id @map("coda_row_id")
  codaCreatedAt DateTime? @map("coda_created_at")
  codaUpdatedAt DateTime? @map("coda_updated_at")
  syncedAt      DateTime  @default(now()) @map("synced_at")
  data          Json

  @@map("mirror_lodicky_po_plavbach")
}

model MirrorHodnoceniPredmetu {
  codaRowId     String    @id @map("coda_row_id")
  codaCreatedAt DateTime? @map("coda_created_at")
  codaUpdatedAt DateTime? @map("coda_updated_at")
  syncedAt      DateTime  @default(now()) @map("synced_at")
  data          Json

  @@map("mirror_hodnoceni_predmetu")
}

model MirrorHodnoceniOblasti {
  codaRowId     String    @id @map("coda_row_id")
  codaCreatedAt DateTime? @map("coda_created_at")
  codaUpdatedAt DateTime? @map("coda_updated_at")
  syncedAt      DateTime  @default(now()) @map("synced_at")
  data          Json

  @@map("mirror_hodnoceni_oblasti")
}

model MirrorKrivka {
  codaRowId     String    @id @map("coda_row_id")
  codaCreatedAt DateTime? @map("coda_created_at")
  codaUpdatedAt DateTime? @map("coda_updated_at")
  syncedAt      DateTime  @default(now()) @map("synced_at")
  data          Json

  @@map("mirror_krivka")
}

model CodaSyncLog {
  tableId      String    @id @map("table_id")
  tableName    String    @map("table_name")
  lastSyncedAt DateTime? @map("last_synced_at")
  rowsSynced   Int       @default(0) @map("rows_synced")
  durationMs   Int?      @map("duration_ms")
  lastError    String?   @map("last_error")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@map("coda_sync_log")
}

model AppPerson {
  id          String   @id @default(cuid())
  dedupKey    String   @unique @map("dedup_key")
  displayName String   @map("display_name")
  nickname    String?
  chipUid     String?  @map("chip_uid")
  chipHid     String?  @map("chip_hid")
  photo       String?
  firstName   String?  @map("first_name")
  middleName  String?  @map("middle_name")
  lastName    String?  @map("last_name")
  identifier  String?
  plus4uId    String?  @map("plus4u_id")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  sourceRecords       AppPersonSourceRecord[]
  loginLinks          AppLoginPersonLink[]
  roles               AppRoleAssignment[]
  parentLinks         AppPersonRelation[]      @relation("ParentPerson")
  childLinks          AppPersonRelation[]      @relation("ChildPerson")
  studentStates       AppStudentState[]
  memberships         AppGroupMembership[]
  violations          AppMembershipViolation[]
  photoFile           AppPersonPhoto?
  studentCalendars    AppStudentCalendar[]
  schoolEventsCreated AppSchoolEvent[]         @relation("AppSchoolEventCreatedBy")
  schoolEventsUpdated AppSchoolEvent[]         @relation("AppSchoolEventUpdatedBy")
  schoolEventTargets  AppSchoolEventTarget[]

  @@index([identifier], map: "app_person_identifier_idx")
  @@index([plus4uId], map: "app_person_plus4u_id_idx")
  @@index([chipUid], map: "app_person_chip_uid_idx")
  @@index([chipHid], map: "app_person_chip_hid_idx")
  @@map("app_person")
}

model AppPersonPhoto {
  personId   String   @id @map("person_id")
  mimeType   String   @map("mime_type")
  content    Bytes
  sizeBytes  Int      @map("size_bytes")
  sourceUrl  String?  @map("source_url")
  sourceHash String?  @map("source_hash")
  fetchedAt  DateTime @default(now()) @map("fetched_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  person AppPerson @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@index([sourceHash], map: "app_person_photo_source_hash_idx")
  @@map("app_person_photo")
}

model AppPersonSourceRecord {
  id                String   @id @default(cuid())
  personId          String   @map("person_id")
  sourceType        String   @map("source_type")
  sourceKey         String   @unique @map("source_key")
  sourcePersonId    String?  @map("source_person_id")
  sourceRecordId    String?  @map("source_record_id")
  organizationIdent String?  @map("organization_ident")
  primaryEmail      String?  @map("primary_email")
  activeSource      Boolean  @default(true) @map("active_source")
  derivedRoles      String[] @default([]) @map("derived_roles")
  payload           Json
  sourceHash        String?  @map("source_hash")
  syncedAt          DateTime @default(now()) @map("synced_at")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  person AppPerson @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@index([personId], map: "app_person_source_record_person_id_idx")
  @@index([sourceType], map: "app_person_source_record_source_type_idx")
  @@index([sourcePersonId], map: "app_person_source_record_source_person_id_idx")
  @@map("app_person_source_record")
}

model AppLoginIdentity {
  id              String   @id @default(cuid())
  identityType    String   @default("email") @map("identity_type")
  identityValue   String   @map("identity_value")
  normalizedValue String   @map("normalized_value")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  personLinks AppLoginPersonLink[]
  conflicts   AppIdentityConflict[]

  @@unique([identityType, normalizedValue], map: "app_login_identity_type_normalized_value_key")
  @@index([normalizedValue], map: "app_login_identity_normalized_value_idx")
  @@map("app_login_identity")
}

model AppLoginPersonLink {
  id         String    @id @default(cuid())
  identityId String    @map("identity_id")
  personId   String    @map("person_id")
  status     String    @default("pending")
  approvedBy String?   @map("approved_by")
  approvedAt DateTime? @map("approved_at")
  reason     String?
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  identity AppLoginIdentity @relation(fields: [identityId], references: [id], onDelete: Cascade)
  person   AppPerson        @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([identityId, personId], map: "app_login_person_link_identity_id_person_id_key")
  @@index([personId], map: "app_login_person_link_person_id_idx")
  @@index([status], map: "app_login_person_link_status_idx")
  @@map("app_login_person_link")
}

model AppRoleAssignment {
  id        String    @id @default(cuid())
  personId  String    @map("person_id")
  role      String
  source    String    @default("auto")
  isActive  Boolean   @default(true) @map("is_active")
  validFrom DateTime? @map("valid_from")
  validTo   DateTime? @map("valid_to")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  person AppPerson @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([personId, role, source], map: "app_role_assignment_person_id_role_source_key")
  @@index([role], map: "app_role_assignment_role_idx")
  @@index([source], map: "app_role_assignment_source_idx")
  @@map("app_role_assignment")
}

model AppPersonRelation {
  id             String   @id @default(cuid())
  parentPersonId String   @map("parent_person_id")
  childPersonId  String   @map("child_person_id")
  relationType   String   @default("parent_of") @map("relation_type")
  source         String   @default("auto")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  parentPerson AppPerson @relation("ParentPerson", fields: [parentPersonId], references: [id], onDelete: Cascade)
  childPerson  AppPerson @relation("ChildPerson", fields: [childPersonId], references: [id], onDelete: Cascade)

  @@unique([parentPersonId, childPersonId, relationType, source], map: "app_person_relation_parent_child_relation_source_key")
  @@index([childPersonId], map: "app_person_relation_child_person_id_idx")
  @@map("app_person_relation")
}

model AppIdentityConflict {
  id              String    @id @default(cuid())
  identityId      String?   @map("identity_id")
  normalizedValue String    @map("normalized_value")
  status          String    @default("open")
  reason          String
  details         Json?
  resolvedBy      String?   @map("resolved_by")
  resolvedAt      DateTime? @map("resolved_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  identity AppLoginIdentity? @relation(fields: [identityId], references: [id], onDelete: SetNull)

  @@index([status], map: "app_identity_conflict_status_idx")
  @@index([normalizedValue], map: "app_identity_conflict_normalized_value_idx")
  @@map("app_identity_conflict")
}

model AppUserSyncRun {
  id                   String    @id @default(cuid())
  source               String
  runType              String    @map("run_type")
  requestedDate        String?   @map("requested_date")
  includeInactiveSince String?   @map("include_inactive_since")
  status               String    @default("running")
  studentsCount        Int       @default(0) @map("students_count")
  employeesCount       Int       @default(0) @map("employees_count")
  csvCount             Int       @default(0) @map("csv_count")
  personsTouched       Int       @default(0) @map("persons_touched")
  error                String?
  startedAt            DateTime  @default(now()) @map("started_at")
  finishedAt           DateTime? @map("finished_at")

  studentStatesChanged AppStudentState[] @relation("SyncRunStudentState")

  @@index([source], map: "app_user_sync_run_source_idx")
  @@index([status], map: "app_user_sync_run_status_idx")
  @@map("app_user_sync_run")
}

model AppStudyModeMap {
  code      String          @id
  modeKey   AppStudyModeKey @map("mode_key")
  label     String
  isActive  Boolean         @default(true) @map("is_active")
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  @@index([modeKey], map: "app_study_mode_map_mode_key_idx")
  @@map("app_study_mode_map")
}

model AppSchoolYear {
  id                String   @id @default(cuid())
  code              String   @unique
  startDate         DateTime @map("start_date") @db.Date
  endDate           DateTime @map("end_date") @db.Date
  teachingStartDate DateTime @map("teaching_start_date") @db.Date
  teachingEndDate   DateTime @map("teaching_end_date") @db.Date
  term1EndDate      DateTime @map("term1_end_date") @db.Date
  term2StartDate    DateTime @map("term2_start_date") @db.Date
  isActive          Boolean  @default(false) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  groups        AppGroup[]
  studentStates AppStudentState[]

  @@map("app_school_year")
}

model AppGroup {
  id           String       @id @default(cuid())
  kind         AppGroupKind
  code         String
  name         String
  schoolYearId String?      @map("school_year_id")
  validFrom    DateTime     @default(now()) @map("valid_from")
  validTo      DateTime?    @map("valid_to")
  isActive     Boolean      @default(true) @map("is_active")
  metadata     Json         @default(dbgenerated("'{}'::jsonb"))
  createdBy    String?      @map("created_by")
  updatedBy    String?      @map("updated_by")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  schoolYear      AppSchoolYear?       @relation(fields: [schoolYearId], references: [id], onDelete: SetNull)
  parentGroupRows AppGroupLink[]       @relation("GroupLinkParent")
  childGroupRows  AppGroupLink[]       @relation("GroupLinkChild")
  memberships     AppGroupMembership[]

  @@unique([kind, code, schoolYearId], map: "app_group_kind_code_school_year_id_key")
  @@index([kind], map: "app_group_kind_idx")
  @@index([schoolYearId], map: "app_group_school_year_id_idx")
  @@map("app_group")
}

model AppGroupLink {
  id            String    @id @default(cuid())
  parentGroupId String    @map("parent_group_id")
  childGroupId  String    @map("child_group_id")
  relationType  String    @map("relation_type")
  validFrom     DateTime  @default(now()) @map("valid_from")
  validTo       DateTime? @map("valid_to")
  createdBy     String?   @map("created_by")
  createdAt     DateTime  @default(now()) @map("created_at")

  parentGroup AppGroup @relation("GroupLinkParent", fields: [parentGroupId], references: [id], onDelete: Cascade)
  childGroup  AppGroup @relation("GroupLinkChild", fields: [childGroupId], references: [id], onDelete: Cascade)

  @@unique([parentGroupId, childGroupId, relationType, validFrom], map: "app_group_link_parent_child_relation_valid_from_key")
  @@index([childGroupId], map: "app_group_link_child_group_id_idx")
  @@map("app_group_link")
}

model AppStudentState {
  id                 String          @id @default(cuid())
  personId           String          @map("person_id")
  sourceType         String          @default("edookit") @map("source_type")
  sourceKey          String          @map("source_key")
  effectiveFrom      DateTime        @map("effective_from")
  effectiveTo        DateTime?       @map("effective_to")
  schoolYearId       String?         @map("school_year_id")
  currentGradeNum    Int?            @map("current_grade_num")
  initialGradeNum    Int?            @map("initial_grade_num")
  studyModeCode      String?         @map("study_mode_code")
  studyModeKey       AppStudyModeKey @default(unknown) @map("study_mode_key")
  changedBySyncRunId String?         @map("changed_by_sync_run_id")
  rawHash            String          @map("raw_hash")
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")

  person           AppPerson       @relation(fields: [personId], references: [id], onDelete: Cascade)
  schoolYear       AppSchoolYear?  @relation(fields: [schoolYearId], references: [id], onDelete: SetNull)
  changedBySyncRun AppUserSyncRun? @relation("SyncRunStudentState", fields: [changedBySyncRunId], references: [id], onDelete: SetNull)

  @@index([personId], map: "app_student_state_person_id_idx")
  @@index([effectiveFrom], map: "app_student_state_effective_from_idx")
  @@index([studyModeKey], map: "app_student_state_study_mode_key_idx")
  @@map("app_student_state")
}

model AppMembershipPolicy {
  id         String         @id @default(cuid())
  scope      AppPolicyScope
  scopeValue String?        @map("scope_value")
  priority   Int            @default(100)
  isActive   Boolean        @default(true) @map("is_active")
  validFrom  DateTime       @default(now()) @map("valid_from")
  validTo    DateTime?      @map("valid_to")
  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime       @updatedAt @map("updated_at")

  rules AppMembershipPolicyRule[]

  @@index([scope, scopeValue], map: "app_membership_policy_scope_scope_value_idx")
  @@index([isActive], map: "app_membership_policy_is_active_idx")
  @@map("app_membership_policy")
}

model AppMembershipPolicyRule {
  id          String       @id @default(cuid())
  policyId    String       @map("policy_id")
  groupKind   AppGroupKind @map("group_kind")
  minCount    Int          @default(0) @map("min_count")
  maxCount    Int?         @map("max_count")
  enforcement String       @default("strict")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  policy AppMembershipPolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  @@unique([policyId, groupKind], map: "app_membership_policy_rule_policy_id_group_kind_key")
  @@index([groupKind], map: "app_membership_policy_rule_group_kind_idx")
  @@map("app_membership_policy_rule")
}

model AppGroupMembership {
  id             String       @id @default(cuid())
  personId       String       @map("person_id")
  groupId        String       @map("group_id")
  groupKind      AppGroupKind @default(studijni_skupina) @map("group_kind")
  membershipRole String?      @map("membership_role")
  validFrom      DateTime     @map("valid_from")
  validTo        DateTime?    @map("valid_to")
  source         String
  reason         String?
  createdBy      String?      @map("created_by")
  updatedBy      String?      @map("updated_by")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  person AppPerson                 @relation(fields: [personId], references: [id], onDelete: Cascade)
  group  AppGroup                  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  events AppGroupMembershipEvent[]

  @@index([personId], map: "app_group_membership_person_id_idx")
  @@index([groupId], map: "app_group_membership_group_id_idx")
  @@index([groupKind], map: "app_group_membership_group_kind_idx")
  @@map("app_group_membership")
}

model AppGroupMembershipEvent {
  id           String   @id @default(cuid())
  membershipId String   @map("membership_id")
  action       String
  changedAt    DateTime @default(now()) @map("changed_at")
  changedBy    String?  @map("changed_by")
  source       String
  oldData      Json?    @map("old_data")
  newData      Json?    @map("new_data")

  membership AppGroupMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@index([membershipId], map: "app_group_membership_event_membership_id_idx")
  @@map("app_group_membership_event")
}

model AppMembershipViolation {
  id             String       @id @default(cuid())
  personId       String       @map("person_id")
  occurredAt     DateTime     @default(now()) @map("occurred_at")
  intervalFrom   DateTime     @map("interval_from")
  intervalTo     DateTime?    @map("interval_to")
  ruleScope      String       @map("rule_scope")
  ruleScopeValue String?      @map("rule_scope_value")
  groupKind      AppGroupKind @map("group_kind")
  expectedMin    Int          @map("expected_min")
  expectedMax    Int?         @map("expected_max")
  actualCount    Int          @map("actual_count")
  severity       String       @default("error")
  source         String
  context        Json         @default(dbgenerated("'{}'::jsonb"))
  resolvedAt     DateTime?    @map("resolved_at")
  resolvedBy     String?      @map("resolved_by")

  person AppPerson @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@index([personId], map: "app_membership_violation_person_id_idx")
  @@index([resolvedAt], map: "app_membership_violation_resolved_at_idx")
  @@map("app_membership_violation")
}

model AppCalendarProviderConfig {
  id                    String              @id @default(cuid())
  provider              AppCalendarProvider @default(GOOGLE_WORKSPACE)
  name                  String
  serviceAccountEmail   String              @map("service_account_email")
  impersonatedUserEmail String              @map("impersonated_user_email")
  workspaceDomain       String?             @map("workspace_domain")
  isActive              Boolean             @default(true) @map("is_active")
  metadata              Json?
  createdAt             DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt             DateTime            @updatedAt @map("updated_at") @db.Timestamptz(3)

  studentCalendars AppStudentCalendar[]
  groupCalendars   AppGroupCalendar[]
  syncJobs         AppCalendarSyncJob[]

  @@unique([provider, name], map: "app_calendar_provider_config_provider_name_key")
  @@index([isActive], map: "app_calendar_provider_config_is_active_idx")
  @@map("app_calendar_provider_config")
}

model AppStudentCalendar {
  id                String    @id @default(cuid())
  providerConfigId  String    @map("provider_config_id")
  personId          String    @map("person_id")
  calendarId        String    @map("calendar_id")
  calendarSummary   String?   @map("calendar_summary")
  timezone          String    @default("Europe/Prague")
