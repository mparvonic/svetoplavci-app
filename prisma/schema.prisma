// Auth.js (NextAuth) + magic link – User, Account, Session, VerificationToken
// https://authjs.dev/getting-started/adapters/prisma
//
// Mirror tabulky = jednosměrná kopie dat z Coda (sync 2x denně).
// Schéma je záměrně jednoduché: coda_row_id (PK) + data JSONB.
// V Phase 3 budou nahrazeny normalizovanými tabulkami.

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  accounts Account[]
  sessions Session[]
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Mirror tabulky (Coda → PostgreSQL) ──────────────────────────────────────

model MirrorSeznamOsob {
  codaRowId     String    @id @map("coda_row_id")
  codaCreatedAt DateTime? @map("coda_created_at")
  codaUpdatedAt DateTime? @map("coda_updated_at")
  syncedAt      DateTime  @default(now()) @map("synced_at")
  data          Json

  @@map("mirror_seznam_osob")
}

model MirrorOsobniLodicky {
  codaRowId     String    @id @map("coda_row_id")
  codaCreatedAt DateTime? @map("coda_created_at")
  codaUpdatedAt DateTime? @map("coda_updated_at")
  syncedAt      DateTime  @default(now()) @map("synced_at")
  data          Json

  @@map("mirror_osobni_lodicky")
}

